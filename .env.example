# GCP project + auth
GCP_PROJECT=your-project-id
GCS_BUCKET=your-bucket-name
BQ_DATASET=naip_pipeline

# Earth Engine auth: leave GEE_SERVICE_ACCOUNT blank to use ADC
# (gcloud auth application-default login).
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=

# Pipeline inputs
INPUT_CSV=../data_us/manufacturing_announcements_geocoded.csv

# AOI + tile geometry
AOI_BUFFER_M=307                 # half-side; 307 m → ~1024 px at NAIP 0.6 m/px
TILE_SIZE_PX=1024
NAIP_DATE_START=2015-01-01
NAIP_DATE_END=2025-12-31

# Phase 2 — Sentinel-2 chip pulling
S2_AOI_BUFFER_M=1280             # half-side; 1280 m → 256 px at 10 m
S2_TILE_SIZE_PX=256
S2_CLOUD_PCT=20                  # max image-level cloud pct for the median composite
S2_YEAR_START=2017
S2_YEAR_END=2025
S2_NEG_SAMPLES=500               # random CONUS negatives
S2_NEG_EXCLUSION_KM=5            # min distance from any anchor
S2_NEG_SEED=42

# SAM (Stage 2)
SAM_CHECKPOINT=/opt/sam/sam_vit_h_4b8939.pth
SAM_MODEL_TYPE=vit_h

# Diff filter (Stage 2 follow-on)
SAM_MIN_AREA_SQM=4645            # ~50,000 sqft floor for industrial-scale
DIFF_OVERLAP_THRESHOLD=0.3       # max overlap with any pre-image polygon to count as "new"
